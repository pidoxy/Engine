// AidCare — Unified PostgreSQL Schema
// Used by: services/api (TypeScript/Prisma) and services/engine (Python/SQLAlchemy)
// Both services connect to the same DATABASE_URL

generator client {
  provider = "prisma-client-js"
  // No custom output — each consuming service generates into its own node_modules/.prisma/client
  // Run: prisma generate --schema=../../packages/database/prisma/schema.prisma
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH & ORGANISATION
// ─────────────────────────────────────────────

model User {
  id                   String        @id @default(uuid())
  firstName            String
  lastName             String
  email                String        @unique
  passwordHash         String
  role                 UserRole      @default(CONSULTANT)
  active               Boolean       @default(true)
  organizationId       String?
  organization         Organization? @relation("OrgUsers", fields: [organizationId], references: [id])
  passwordChangedAt    DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  consultations   Consultation[]    @relation("ConsultantConsultations")
  createdPatients Patient[]         @relation("PatientCreatedBy")
  createdOrgs     Organization[]    @relation("OrgCreatedBy")

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdById String?
  createdBy   User?    @relation("OrgCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]    @relation("OrgUsers")
  patients Patient[] @relation("OrgPatients")
  roles    Role[]

  @@map("organizations")
}

model Role {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    String[]     @default([])
  description    String?
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("roles")
}

// ─────────────────────────────────────────────
// PATIENT
// ─────────────────────────────────────────────

model Patient {
  id             String        @id @default(uuid())
  firstName      String
  lastName       String
  phoneNumber    String?
  dateOfBirth    DateTime?
  gender         Gender        @default(PREFER_NOT_TO_SAY)
  isActive       Boolean       @default(true)
  organizationId String?
  organization   Organization? @relation("OrgPatients", fields: [organizationId], references: [id])
  createdById    String?
  createdBy      User?         @relation("PatientCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  consultations Consultation[]
  documents     PatientDocument[]

  @@index([organizationId])
  @@index([firstName, lastName])
  @@index([phoneNumber])
  @@index([isActive])
  @@map("patients")
}

// ─────────────────────────────────────────────
// CONSULTATION  (merges Backend Consultation + Engine ConsultationSession)
// ─────────────────────────────────────────────

model Consultation {
  id           String           @id @default(uuid())
  title        String           @default("New Consultation")
  consultantId String?
  consultant   User?            @relation("ConsultantConsultations", fields: [consultantId], references: [id])
  patientId    String
  patient      Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  mode         ConsultationMode @default(CHW_TRIAGE)
  isActive     Boolean          @default(true)

  // AI pipeline fields (from Engine ConsultationSession)
  audioFilePath            String?
  transcriptText           String?
  manualContextInput       String?
  extractedInfoJson        Json?
  retrievedDocsSummaryJson Json?
  finalRecommendationJson  Json?

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Chat[]
  documents PatientDocument[]

  @@index([consultantId, createdAt(sort: Desc)])
  @@index([patientId, createdAt(sort: Desc)])
  @@index([isActive])
  @@map("consultations")
}

// ─────────────────────────────────────────────
// CHAT  (real-time messages per consultation)
// ─────────────────────────────────────────────

model Chat {
  id             String       @id @default(uuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  sender         ChatSender
  userMessage    String?
  // AI response data — flexible JSON to support both triage and clinical modes
  triageData     Json?
  clinicalData   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([consultationId, createdAt(sort: Desc)])
  @@map("chats")
}

// ─────────────────────────────────────────────
// PATIENT DOCUMENTS  (from Engine PatientDocument)
// ─────────────────────────────────────────────

model PatientDocument {
  id               String        @id @default(uuid())
  patientId        String
  patient          Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultationId   String?
  consultation     Consultation? @relation(fields: [consultationId], references: [id])
  originalFilename String
  storagePath      String
  fileType         String?
  extractedText    String?
  processingStatus String        @default("queued")
  uploadedAt       DateTime      @default(now())
  processedAt      DateTime?
  errorMessage     String?

  @@index([patientId])
  @@index([consultationId])
  @@index([processingStatus])
  @@map("patient_documents")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  CONSULTANT
  ORGANIZATION
  COMMUNITY_HEALTH_WORKER

  @@map("user_role")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY

  @@map("gender")
}

enum ConsultationMode {
  CHW_TRIAGE
  CLINICAL_SUPPORT

  @@map("consultation_mode")
}

enum ChatSender {
  USER
  SYSTEM

  @@map("chat_sender")
}
