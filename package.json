{
  "name": "aidcare",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/api",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate --filter=@aidcare/database",
    "db:migrate": "turbo db:migrate --filter=@aidcare/database",
    "db:studio": "turbo db:studio --filter=@aidcare/database"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
