# AidCare Lang App — Environment Variables
# Copy to .env.local for local development
# Set on Vercel dashboard for production (lang.theaidcare.com)

# Shared backend API URL
NEXT_PUBLIC_API_BASE_URL=https://api.theaidcare.com

# ElevenLabs Voice IDs — Audit at elevenlabs.io/voice-library
# Filter by language, test a medical sentence, record the best voice ID
NEXT_PUBLIC_VOICE_EN=EXAVITQu4vr4xnSDxMaL
NEXT_PUBLIC_VOICE_HA=REPLACE_WITH_HAUSA_VOICE_ID
NEXT_PUBLIC_VOICE_YO=REPLACE_WITH_YORUBA_VOICE_ID
NEXT_PUBLIC_VOICE_IG=REPLACE_WITH_IGBO_VOICE_ID
NEXT_PUBLIC_VOICE_PCM=REPLACE_WITH_PIDGIN_VOICE_ID
