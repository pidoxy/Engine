# AidCare Monorepo — Root Environment Variables
# Copy to .env and fill in values for local dev
# Each service also has its own .env — see services/*/env.example and apps/*/.env.example

# ─── Shared database ──────────────────────────
# Both services/api and services/engine use this
DATABASE_URL=postgresql://aidcare:aidcare_dev@localhost:5432/aidcare
