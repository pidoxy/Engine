# ─────────────────────────────────────────────────────────
# AidCare TypeScript API — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string (shared with the Python Engine)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/aidcare"

# ── Authentication ────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="90d"

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000,https://theaidcare.com,https://www.theaidcare.com"

# ── AI Engine ─────────────────────────────────────────────
# URL of the FastAPI Python Engine (services/engine)
ENGINE_URL="https://aidcare-triage-production.up.railway.app"

# ── Email (Nodemailer) ────────────────────────────────────
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USERNAME="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="AidCare <noreply@theaidcare.com>"

# ── App ───────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
