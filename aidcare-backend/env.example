#
# AidCare backend environment variables (example)
#
# Create `aidcare-backend/.env` locally (gitignored) and copy these values.
#

# Required for Gemini calls (symptom extraction + recommendations + clinical support)
GOOGLE_API_KEY="YOUR_GOOGLE_AI_STUDIO_API_KEY"

# Use the free-tier Gemini 3 model (Flash preview) by default.
# Docs: https://ai.google.dev/gemini-api/docs/gemini-3
GEMINI_MODEL_EXTRACTION="gemini-3-flash-preview"
GEMINI_MODEL_RECOMMEND="gemini-3-flash-preview"
GEMINI_MODEL_CLINICAL_EXTRACT="gemini-3-flash-preview"
GEMINI_MODEL_CLINICAL_SUPPORT="gemini-3-flash-preview"

# Optional DB config (uncomment if you use Postgres)
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

