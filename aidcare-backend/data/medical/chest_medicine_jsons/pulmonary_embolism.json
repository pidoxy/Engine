{
  "disease": "Pulmonary Embolism",
  "synonyms": [
    "PE"
  ],
  "category": "Respiratory Medicine",
  "description": "PE is a blockage of a pulmonary artery by a thrombus, commonly originating from the deep veins of the legs.",
  "epidemiology": {
    "prevalence": "Relatively common and potentially fatal; associated with immobility, surgery, and cancer",
