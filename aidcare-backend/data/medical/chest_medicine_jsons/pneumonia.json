  },
  "symptoms": [
    "Fever",
    "Cough with sputum",
    "Pleuritic chest pain",
    "Dyspnoea",
    "Rigors",
    "Confusion (especially in elderly)"
  ],
  "diagnosis": {
    "clinical": [
      "Crackles and bronchial breathing on auscultation",
      "Dullness to percussion"
    ],
    "investigations": [
      "Chest X-ray: consolidation",
      "Full blood count",
      "CRP/ESR",
      "Sputum culture",
      "Blood culture if sepsis suspected"
    ],
